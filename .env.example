# Optional settings. You only need a .env if you want the extras below.
# Copy this file to ".env" and fill in what you want.

# Change the port the website runs on (default 3000).
# PORT=3000

# Reminders can also be sent to Slack (optional/advanced). If you set both,
# scheduled messages post to Slack too. Otherwise they pop up as a desktop
# notification, which is all most people need.
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_CHANNEL=C0123ABC
